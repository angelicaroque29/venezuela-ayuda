# OpenAI — triaje por lotes (opcional; modo demo sin key)
OPENAI_API_KEY=

# Máximo reportes por lote (control de tokens, default 50)
MAX_REPORTS_PER_BATCH=50

# Secreto para cron (GitHub Actions) — genera con: npm run generate-cron-secret
CRON_SECRET=

# ─── WHATSAPP ───────────────────────────────────────────────
# Número para el botón "Reportar por WhatsApp"
# Formato: código país + número, SIN + ni espacios
# Ejemplo Venezuela: 584121234567  (58 = país, 412 = móvil)
#
# Local:      crea .env.local con esta variable
# Vercel:     Settings → Environment Variables → NEXT_PUBLIC_WHATSAPP_NUMBER
#
NEXT_PUBLIC_WHATSAPP_NUMBER=584121234567

# Vercel KV — auto-configurado al crear KV en dashboard Vercel
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
