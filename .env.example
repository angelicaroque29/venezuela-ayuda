# OpenAI — triaje por lotes (opcional; modo demo sin key)
OPENAI_API_KEY=

# Máximo reportes por lote (control de tokens, default 50)
MAX_REPORTS_PER_BATCH=50

# Secreto para cron (GitHub Actions) — genera con: npm run generate-cron-secret
CRON_SECRET=

# Vercel KV — obligatorio en producción para que los reportes persistan
# Se configuran al crear KV en dashboard Vercel → Storage → KV → Connect
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (Alternativa Upstash: UPSTASH_REDIS_REST_URL y UPSTASH_REDIS_REST_TOKEN)
