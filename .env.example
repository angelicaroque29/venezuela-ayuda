# OpenAI — triaje por lotes (opcional; modo demo sin key)
OPENAI_API_KEY=

# Máximo reportes por lote (control de tokens, default 50)
MAX_REPORTS_PER_BATCH=50

# Secreto para cron de Vercel (Vercel lo inyecta en plan Pro, o créalo manualmente)
CRON_SECRET=

# Secreto alternativo para POST manual a /api/batch
BATCH_CRON_SECRET=

# WhatsApp para reportes
NEXT_PUBLIC_WHATSAPP_NUMBER=584121234567

# Vercel KV — auto-configurado al crear KV en dashboard Vercel
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
